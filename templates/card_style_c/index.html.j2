<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=360">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Gasoek+One&family=Gugi&family=Jua&family=Noto+Sans+KR:wght@400;500;700;800&display=swap" rel="stylesheet">
  <style>
    /* ══════════════════════════════════════════════════════════════
       card_style_c — "Sunset Pop"
       Bright, playful, warm sunset gradient with a frosted glass panel.
       High-energy for lifestyle / fun content.
       ══════════════════════════════════════════════════════════════ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 360px;
      height: 640px;
      background: linear-gradient(155deg, #ff7a59 0%, #ff5c8a 45%, #b14bd8 100%);
      font-family: 'Noto Sans KR', sans-serif;
      color: #ffffff;
      overflow: hidden;
      position: relative;
    }

    /* Soft light blooms */
    body::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 55% 35% at 20% 12%, rgba(255, 220, 150, 0.45) 0%, transparent 65%),
        radial-gradient(ellipse 55% 40% at 85% 90%, rgba(120, 80, 255, 0.35) 0%, transparent 65%);
      pointer-events: none;
    }

    .card {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      padding: 52px 26px 68px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    /* ── Title ── */
    .title {
      font-family: 'Noto Sans KR', sans-serif;
      font-weight: 800;
      font-size: 31px;
      line-height: 1.3;
      letter-spacing: -0.3px;
      color: #ffffff;
      text-shadow: 0 3px 14px rgba(120, 20, 90, 0.28);
      word-break: keep-all;
    }

    /* ── Hook ── */
    .hook {
      font-size: 12.5px;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.92);
      line-height: 1.65;
      letter-spacing: 0.1px;
      word-break: keep-all;
    }

    /* ── Divider ── */
    .divider {
      width: 40px;
      height: 3px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.9);
      flex-shrink: 0;
    }

    /* Shared frosted-glass look */
    .glass {
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 14px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      box-shadow: 0 6px 18px rgba(120, 30, 90, 0.14);
    }

    /* ── VARIANT: numbered_list ── */
    .body-numbered {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 10px;
    }
    .body-numbered .point {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 14px;
    }
    .body-numbered .num {
      font-family: '{{ header_font }}', 'Jua', sans-serif;
      font-size: 24px;
      color: #fff2b8;
      text-shadow: 0 2px 8px rgba(120, 30, 0, 0.3);
      min-width: 26px;
      line-height: 1.35;
      flex-shrink: 0;
    }
    .body-numbered .text {
      font-size: 14.5px;
      font-weight: 500;
      color: #ffffff;
      line-height: 1.5;
      word-break: keep-all;
    }

    /* ── VARIANT: accent_line ── */
    .body-accent {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 14px;
    }
    .body-accent .point {
      border-left: 3px solid rgba(255, 255, 255, 0.9);
      padding: 9px 0 9px 16px;
      font-size: 15.5px;
      font-weight: 600;
      color: #ffffff;
      line-height: 1.6;
      word-break: keep-all;
    }

    /* ── VARIANT: grid ── */
    .body-grid {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 1fr;
      gap: 10px;
    }
    .body-grid .point {
      padding: 14px 12px;
      font-size: 14px;
      font-weight: 600;
      color: #ffffff;
      line-height: 1.5;
      word-break: keep-all;
      display: flex;
      align-items: center;
    }

    /* ── Tags ── */
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: auto;
      padding-top: 6px;
    }
    .tag {
      font-size: 10px;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.85);
      background: rgba(255, 255, 255, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.25);
      border-radius: 20px;
      padding: 3px 9px;
      letter-spacing: 0.2px;
    }
  </style>
</head>
<body>
  <div class="card">

    <h1 class="title">{{ title }}</h1>
    <p class="hook">{{ hook }}</p>
    <div class="divider"></div>

    {# ── numbered_list ── #}
    {% if variant == 'numbered_list' %}
    <div class="body-numbered">
      {% for point in body_points %}
      <div class="point glass">
        <span class="num">{{ loop.index }}</span>
        <span class="text">{{ point }}</span>
      </div>
      {% endfor %}
    </div>

    {# ── accent_line ── #}
    {% elif variant == 'accent_line' %}
    <div class="body-accent">
      {% for point in body_points %}
      <div class="point">{{ point }}</div>
      {% endfor %}
    </div>

    {# ── grid ── #}
    {% elif variant == 'grid' %}
    <div class="body-grid">
      {% for point in body_points %}
      <div class="point glass">{{ point }}</div>
      {% endfor %}
    </div>

    {% endif %}

    <div class="tags">
      {% for tag in tags[:6] %}
      <span class="tag">#{{ tag }}</span>
      {% endfor %}
    </div>

  </div>
</body>
</html>
