<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=360">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Gasoek+One&family=Gugi&family=Nanum+Myeongjo:wght@400;700;800&family=Noto+Serif+KR:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    /* ══════════════════════════════════════════════════════════════
       card_style_b — "Warm Paper"
       Light, editorial, cream background with ink-serif type.
       A calm counterpart to the neon card_style_a.
       ══════════════════════════════════════════════════════════════ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 360px;
      height: 640px;
      background: #f4ede0;
      font-family: 'Noto Serif KR', serif;
      color: #2b2419;
      overflow: hidden;
      position: relative;
    }

    /* Subtle paper grain + warm vignette */
    body::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 50% 0%, rgba(210, 160, 90, 0.14) 0%, transparent 70%),
        radial-gradient(ellipse 80% 60% at 50% 100%, rgba(120, 80, 40, 0.10) 0%, transparent 70%);
      pointer-events: none;
    }

    .card {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      padding: 56px 30px 72px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ── Title ── */
    .title {
      font-family: 'Noto Serif KR', serif;
      font-size: 29px;
      font-weight: 700;
      line-height: 1.32;
      letter-spacing: -0.2px;
      color: #1f1a12;
      word-break: keep-all;
    }

    /* ── Hook ── */
    .hook {
      font-size: 13.5px;
      font-weight: 400;
      color: #7a6a52;
      line-height: 1.7;
      letter-spacing: 0.1px;
      font-style: italic;
      word-break: keep-all;
    }

    /* ── Divider ── */
    .divider {
      width: 40px;
      height: 2px;
      background: #b5772e;
      flex-shrink: 0;
    }

    /* ── VARIANT: numbered_list ── */
    .body-numbered {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 10px;
    }
    .body-numbered .point {
      display: flex;
      align-items: flex-start;
      gap: 13px;
      background: rgba(255, 255, 255, 0.5);
      border: 1px solid rgba(120, 80, 40, 0.16);
      padding: 12px 15px;
    }
    .body-numbered .num {
      font-family: '{{ header_font }}', 'Nanum Myeongjo', serif;
      font-size: 25px;
      font-weight: 800;
      color: #b5772e;
      min-width: 26px;
      line-height: 1.35;
      flex-shrink: 0;
    }
    .body-numbered .text {
      font-size: 14.5px;
      font-weight: 500;
      color: #3a3226;
      line-height: 1.55;
      word-break: keep-all;
    }

    /* ── VARIANT: accent_line ── */
    .body-accent {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 14px;
    }
    .body-accent .point {
      border-left: 3px solid #b5772e;
      padding: 10px 0 10px 16px;
      font-size: 15.5px;
      font-weight: 500;
      color: #3a3226;
      line-height: 1.55;
      word-break: keep-all;
    }

    /* ── VARIANT: grid ── */
    .body-grid {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 1fr;
      gap: 10px;
    }
    .body-grid .point {
      background: rgba(255, 255, 255, 0.55);
      border: 1px solid rgba(120, 80, 40, 0.18);
      padding: 14px 12px;
      font-size: 14px;
      font-weight: 500;
      color: #3a3226;
      line-height: 1.55;
      word-break: keep-all;
      display: flex;
      align-items: center;
    }

    /* ── Tags ── */
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: auto;
      padding-top: 6px;
    }
    .tag {
      font-family: 'Noto Serif KR', serif;
      font-size: 10px;
      font-weight: 400;
      color: #9a8a70;
      background: rgba(120, 80, 40, 0.05);
      border: 1px solid rgba(120, 80, 40, 0.14);
      padding: 3px 8px;
      letter-spacing: 0.2px;
    }
  </style>
</head>
<body>
  <div class="card">

    <h1 class="title">{{ title }}</h1>
    <p class="hook">{{ hook }}</p>
    <div class="divider"></div>

    {# ── numbered_list ── #}
    {% if variant == 'numbered_list' %}
    <div class="body-numbered">
      {% for point in body_points %}
      <div class="point">
        <span class="num">{{ loop.index }}</span>
        <span class="text">{{ point }}</span>
      </div>
      {% endfor %}
    </div>

    {# ── accent_line ── #}
    {% elif variant == 'accent_line' %}
    <div class="body-accent">
      {% for point in body_points %}
      <div class="point">{{ point }}</div>
      {% endfor %}
    </div>

    {# ── grid ── #}
    {% elif variant == 'grid' %}
    <div class="body-grid">
      {% for point in body_points %}
      <div class="point">{{ point }}</div>
      {% endfor %}
    </div>

    {% endif %}

    <div class="tags">
      {% for tag in tags[:6] %}
      <span class="tag">#{{ tag }}</span>
      {% endfor %}
    </div>

  </div>
</body>
</html>
